{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "shopbillpro.in" }],
      "destination": "/site/index.html"
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.shopbillpro.in" }],
      "destination": "/site/index.html"
    },
    { "source": "/s/:slug", "destination": "/s.html" },
    { "source": "/pricing", "destination": "/site/pricing.html" },
    { "source": "/faq", "destination": "/site/faq.html" },
    { "source": "/why-choose-shopbill-pro", "destination": "/site/why-choose-shopbill-pro.html" },
    { "source": "/free-billing-software-india", "destination": "/site/free-billing-software-india.html" },
    { "source": "/features/:slug", "destination": "/site/features/:slug.html" },
    { "source": "/for/:slug", "destination": "/site/for/:slug.html" },
    { "source": "/sitemap.xml", "destination": "/site/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/site/robots.txt" }
  ],
  "redirects": [
    {
      "source": "/index.html",
      "has": [{ "type": "host", "value": "shopbillpro.in" }],
      "destination": "/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/site/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
