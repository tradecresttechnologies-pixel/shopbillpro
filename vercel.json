{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/login",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/signup",
      "destination": "/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/s/:slug",
      "destination": "https://jfqeirfrkjdkqqixivru.supabase.co/functions/v1/shop-page?slug=:slug"
    },
    {
      "source": "/s/:slug/:rest*",
      "destination": "https://jfqeirfrkjdkqqixivru.supabase.co/functions/v1/shop-page?slug=:slug"
    },
    {
      "source": "/sitemap-shops.xml",
      "destination": "https://jfqeirfrkjdkqqixivru.supabase.co/functions/v1/shop-sitemap"
    },
    {
      "source": "/:path*",
      "missing": [
        {
          "type": "host",
          "value": "(.+\\.)?shopbillpro\\.in"
        }
      ],
      "destination": "/domain-router"
    },
    {
      "source": "/qr/:slug/:table",
      "destination": "/qr-menu"
    }
  ],
  "headers": [
    {
      "source": "/icons/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/.well-known/:key.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/sitemap-shops.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    }
  ]
}