{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/login",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/signup",
      "destination": "/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "missing": [
        {
          "type": "host",
          "value": "(.+\\.)?shopbillpro\\.in"
        }
      ],
      "destination": "/domain-router"
    },
    {
      "source": "/s/:slug",
      "destination": "/s"
    },
    {
      "source": "/qr/:slug/:table",
      "destination": "/qr-menu"
    }
  ],
  "headers": [
    {
      "source": "/icons/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
